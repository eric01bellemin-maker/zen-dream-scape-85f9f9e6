<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.querySelector('.fr-sidebar-element');
    if (!sidebar) return;

    let lastScrollY = window.scrollY;

    window.addEventListener(
      'scroll',
      () => {
        const currentScrollY = window.scrollY;

        if (currentScrollY < lastScrollY) {
          // scrolling up
          sidebar.style.top = '190px';
        } else {
          // scrolling down
          sidebar.style.top = '40px';
        }

        lastScrollY = currentScrollY;
      },
      { passive: true }
    );
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyBtn = document.querySelector('.copy-link');
    if (!copyBtn) return;

    copyBtn.addEventListener('click', (e) => {
      e.preventDefault();

      navigator.clipboard.writeText('https://milky-mama.com/en-eu/blogs/lactation-support/is-breastfeeding-and-pumping-making-you-tired-understanding-and-conquering-postpartum-exhaustion').then(() => {
        alert('Link copied to clipboard');
      });
    });
  });
</script>

<script>
  const swiper = new Swiper('.swiper', {
    slidesPerView: 1,
    spaceBetween: 24,
    slidesOffsetBefore: 16,
    slidesOffsetAfter: 16,
    navigation: {
      nextEl: '.swiper-custom-button-next',
      prevEl: '.swiper-custom-button-prev',
    },
    breakpoints: {
      768: {
        slidesPerView: 2.2,
      },
      1440: {
        slidesPerView: 2.5,
        slidesOffsetBefore: 56,
        slidesOffsetAfter: 56,
      },
    },
  });
</script>

<script>
  window.addEventListener('load', () => {
    const articleContent = document.querySelector('.fr-article-content');
    const banner = articleContent?.querySelector('.fr-mid-collection');
    if (!articleContent || !banner) return;

    const h2s = articleContent.querySelectorAll('h2');
    if (h2s.length < 3) return;

    const targetH2 = h2s[4]; // 5th h2 (0-based index)
    articleContent.insertBefore(banner, targetH2);
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const OFFSET = 20;

    document.querySelectorAll('.content-table a[href^="#"]').forEach((link) => {
      link.addEventListener('click', (e) => {
        const targetId = link.getAttribute('href');
        const targetEl = document.querySelector(targetId);

        if (!targetEl) return;

        e.preventDefault();

        const elementPosition = targetEl.getBoundingClientRect().top;
        const offsetPosition = elementPosition + window.pageYOffset - OFFSET;

        window.scrollTo({
          top: offsetPosition,
          behavior: 'smooth',
        });

        // Update URL hash without jumping
        history.pushState(null, '', targetId);
      });
    });
  });
</script>

  <!-- BEGIN app block: shopify://apps/onward/blocks/onward-protection-embed/b53f9cdb-2bd0-4ef4-be64-bb0b8b7f7dff --><script type="text/javascript">
  window.addEventListener('DOMContentLoaded', () => {
  const onward = new OnwardSetup();

  // DRAWER
  onward.addContainer('.dyn-cart #dyn-cart-bottom-section #dyn-checkout', { position: 'beforebegin' });
  onward.attachCheckoutButton('.dyn-cart #dyn-cart-bottom-section #dyn-checkout', {
    optOutSelector: '.dyn-cart #dyn-cart-bottom-section #dyn-checkout',
    optOutPosition: 'afterend',
  });

  // CART PAGE
  onward.addContainer('.cart__footer .cart__blocks .js-contents', { position: 'beforeend' });
  onward.attachCheckoutButton('.cart__footer .cart__ctas button#checkout', {
    optOutSelector: '.cart__footer .cart__ctas button#checkout',
    optOutPosition: 'afterend',

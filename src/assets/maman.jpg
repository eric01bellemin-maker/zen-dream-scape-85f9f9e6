mendationIntent":null,"selectedProducts":[{"product_id":"8789491155190","product_title":"Breastfeeding 101","product_image":"https:\/\/cdn.shopify.com\/s\/files\/1\/0681\/5671\/9350\/files\/43bPU4bXSxGVud9aPEVl_Untitled_20design_20-_202020-03-27T184019.448.png?v=1741751367","product_images":["https:\/\/cdn.shopify.com\/s\/files\/1\/0681\/5671\/9350\/files\/43bPU4bXSxGVud9aPEVl_Untitled_20design_20-_202020-03-27T184019.448.png?v=1741751367","https:\/\/cdn.shopify.com\/s\/files\/1\/0681\/5671\/9350\/files\/preview_images\/Screenshot_2024-08-08_at_2.22.26_PM_c1290788-d2f8-4d35-afca-dbf492161ad2.png?v=1723152182"],"product_description":["In Breastfeeding 101, you'll learn everything you need to know about breastfeeding from the owner and founder of Milky Mama, Krystal Duhaney. Krystal is a Registered Nurse, International Board Certified Lactation Consultant, and breastfeeding Mama of two. She's helped thousands of Mamas just like you learn how to successfully breastfeed their babies -- and now she will help you experience the best breastfeeding journey possible inside her online course. What We're Covering in The Course WHEN YOU ENROLL IN BREASTFEEDING 101, YOU'LL GAIN LIFETIME ACCESS TO ALL COURSE CONTENT INCLUDING: THE BENEFITS OF BREASTFEEDING Learn how breastfeeding can help protect you and your baby from diseases, speed up recovery from childbirth, save your family money and so much more PREPARING FOR BREASTFEEDING Understand how your body produces milk, when your milk will arrive and how you can ensure you and your baby get off to a good start BREASTFEEDING EXPECTATIONS Master the ins and outs of latching, expressing milk, identifying important hunger cues and determining whether your baby is getting enough milk UNDERSTANDING YOUR MILK SUPPLY Determine how to correctly identify if and when your milk supply is low and learn what to do to effectively increase your supply FINDING YOUR BREAST FRIENDS Discover ways to build your village and connect with other breastfeeding parents or certified lactation consultants EXCLUSIVE BONUSES FOR STUDENTS Gain access to our private Facebook community, printable guides and exclusive discounts on amazing products"],"product_collections":[{"id":"gid:\/\/shopify\/Collection\/421201543414","title":"all"},{"id":"gid:\/\/shopify\/Collection\/426749133046","title":"All Products"},{"id":"gid:\/\/shopify\/Collection\/434568691958","title":"Courses"}],"product_variants":[{"variant_id":"47082176348406","variant_title":"Default Title","variant_available":true,"variant_price":"50.00","inventory_quantity":-195,"inventory_policy":"DENY","display_name":"Breastfeeding 101 - Default Title","compare_at_price":null,"taxable":true}],"changes":[{"variantId":"47082176348406","type":"add_variant","title":"Default Title","quantity":1}]}],"selectedFeeds":[]},"general":{"hideHeading":true,"heading_align":"center","ppHideTopLine":true,"ppHideMidLine":true,"ppHideBottomLine":true,"ppHeadingTopLineText":"It’s not too late to add this to your order","ppHeadingMidLineText":"Add it to your order and save","ppHeadingBottomLineText":"Limited Time Offer!","ppTimerFulfillmentText":"Offer Period Over!","ppTimeLimit":"30","ppDiscountAmount":50,"ppPayNowBtnText":"Enroll Now","ppDeclineBtnText":"No Thanks"}},"advance":{"devices":{"showOnMobile":true,"showOnTablet":true,"showOnDesktop":true}}}},"customize_widget":"","product_in_widget":"","selected_widget":{"value":{"id":102,"title":"Single Product Upsell","slug":"SingleProductUpsellNew","description":"Use this template to offer a single product post purchase upsell.","img":"https:\/\/dashboard.dynamatics.app\/images\/spu_widget.png","category":["post_purchase"]},"parentWidgetId":"widget_0"},"active":1,"deleted_at":null,"created_at":"2024-06-12T07:56:40.000000Z","updated_at":"2024-08-09T16:55:47.000000Z","page_type":["post_purchase"],"template":102,"unique_id":"9854771944301897","template_variant":"single_product_upsell_1","name":"Post purchase upsell - BF101","products_in_widget":{"type":"Recommendation","products":[]},"currency_code":"USD","allocation":0}],"custom_live_from":"Tue Jun 11 2024 11:52:00 GMT-07:00","live_from":"2024-06-11 11:52:00","live_to":null,"never_expire":1}],"custom_live_from":"Tue Jun 11 2024 11:52:00 GMT-07:00","custom_live_to":null,"enabled_experience":null}]}]},"ZID0143-47795091717713507-SLIDECART":{"id":388,"name":"Navidium","category_name":"Slide Cart","currency_code":"USD","zone_id":"ZID0143-47795091717713507-SLIDECART","zone_type":"Slide Cart","is_static":0,"cart_type":"active","zone_position":{"name":"cart_bottom"},"audiences":[]},"ZID0143-47798581724605812-SLIDECART":{"id":740,"name":"Cart Page - Free Gift","category_name":"Slide Cart","currency_code":"USD","zone_id":"ZID0143-47798581724605812-SLIDECART","zone_type":"Slide Cart","is_static":1,"cart_type":"active","zone_position":{"name":"before_lineitem"},"audiences":[]}};
  
  if (Object.keys(metafieldData)?.length) {
    duplicateProducts = metafieldData[optionId];
  } else {
    // Array of duplicate products
    duplicateProducts = [
      { "the-complete-snowboard": "the_complete_snowboard_dyn_product_option" },
      { "the-complete-ski": "the_complete_ski_dyn_product_option" },
      { "the-complete-snowshoe": "the_complete_snowshoe_dyn_product_option" }
      // Add more duplicate products as needed
    ];
  }
  const settingId =  window.Shopify?.shop?.replace(".myshopify.com", "_product_options").replaceAll(".", "_").replaceAll("-","_");
   
  
  const appData = metafieldData[settingId]
  
  const selectors = appData?.settings?.css_selector
  

  // Get all product card elements
  const productCards = document.querySelectorAll( "."+selectors?.product_gallery_container  ?? '.grid__item');

  // Loop through each product card and check for duplicates
  productCards?.forEach(card => {
    // Find the first <a> tag within the product card (assuming it's the product link)
    const productLink = card.querySelector('a');
    const productHandle = productLink ? productLink.getAttribute('href') : '';



    // Loop through the duplicateProducts array
    duplicateProducts?.forEach(duplicate => {
      const productKey = Object.keys(duplicate)[0];  // Main product key
      const productValue = duplicate[productKey];    // Duplicate product handle

      // Check if the product link contains the duplicate product handle
      if (productHandle.includes(productValue)) {
        // Remove the card from the DOM
        card.remove();
      }
    });
  });
</script>

<script>
	// removes child if parent is missing from bundle
	window.addEventListener('dynamaticcart', e => {
		const { cart } = e.detail
		const itemsToRemove = {}
		const deletedParents = new Set()
		cart.items.forEach(item => {
			let randomId
			if ('__dyn_widgetProduct' in item.properties) {
				randomId = item.properties.__dyn_widgetProduct.split(':').at(-1)
				deletedParents.add(randomId)
				delete itemsToRemove[randomId]
			}
			if ('__dyn_addOnProduct' in item.properties) {
				randomId = item.properties.__dyn_addOnProduct.split(':').at(-1)
				if (deletedParents.has(randomId)) {
					delete itemsToRemove[randomId]
				} else {
					itemsToRemove[randomId] = {
						...(itemsToRemove[randomId] || {}),
						[item.key]: 0
					}
				}
			}
		})
		let updates = {}
		for (const item in itemsToRemove) {
			updates = {
				...updates,
				...itemsToRemove[item]
			}
		}
		if (Object.keys(updates).length) {
			fetch('/cart/update.js', {
				method: 'post',
				keepalive: true,
				headers: {
					'content-type': 'application/json'
				},
				body: JSON.stringify({
					updates
				})
			}).then(() => {
				if (window.location.pathname.startsWith('/cart')) window.location.reload()
			})
		}
	})
</script>

